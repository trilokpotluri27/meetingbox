ANTHROPIC_API_KEY=sk-ant-api03-your-key-here

# Optional: override default models/settings in services
AI_MODEL=claude-sonnet-4-20250514
AI_MAX_TOKENS=2000

# Local LLM model for Ollama (used by "Summarize Locally" button)
# Options: phi3:mini (best quality/size ratio, ~2.5GB RAM), qwen2.5:3b
# You must pull the model first: docker compose exec ollama ollama pull phi3:mini
LOCAL_LLM_MODEL=phi3:mini

# JWT secret for user authentication (change in production!)
JWT_SECRET_KEY=meetingbox-dev-secret-change-in-production

# Google OAuth2 (for Gmail + Calendar integrations)
# 1. Go to: https://console.cloud.google.com/apis/credentials
# 2. Create OAuth client ID with type: "TVs and Limited Input devices"
#    (or "Desktop app" — both work; no redirect URI needed)
# 3. Enable Gmail API and Google Calendar API in your project
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

