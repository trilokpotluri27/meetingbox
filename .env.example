ANTHROPIC_API_KEY=sk-ant-api03-your-key-here

# Optional: override default models/settings in services
AI_MODEL=claude-sonnet-4-20250514
AI_MAX_TOKENS=2000

# Local LLM model for Ollama (used by "Summarize Locally" button)
# Options: phi3:mini (best quality/size ratio, ~2.5GB RAM), qwen2.5:3b
# You must pull the model first: docker compose exec ollama ollama pull phi3:mini
LOCAL_LLM_MODEL=phi3:mini

# JWT secret for user authentication (REQUIRED in production).
# Generate one with: openssl rand -hex 32
JWT_SECRET_KEY=replace_with_a_strong_random_secret

# Google OAuth2 (for Gmail + Calendar integrations)
# 1. Go to: https://console.cloud.google.com/apis/credentials
# 2. Create OAuth client ID with type: "Web application"
# 3. Under "Authorized redirect URIs", add:
#      http://localhost:8000/api/integrations/gmail/callback
#      http://localhost:8000/api/integrations/calendar/callback
#    (replace localhost:8000 with your APP_BASE_URL if different)
# 4. Enable Gmail API and Google Calendar API in your project
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Base URL of the web backend (used to build OAuth redirect URIs)
# Set this to the URL you access MeetingBox from, e.g.:
#   http://meetingbox.local:8000  or  http://192.168.1.100:8000
APP_BASE_URL=http://localhost:8000

# Optional explicit frontend URL for OAuth callback redirects (defaults to APP_BASE_URL)
FRONTEND_BASE_URL=http://localhost:8000

